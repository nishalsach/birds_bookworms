@inproceedings{adukiaTalesTropesGender2022,
  title = {Tales and {{Tropes}}: {{Gender Roles}} from {{Word Embeddings}} in a {{Century}} of {{Children}}'s {{Books}}},
  shorttitle = {Tales and {{Tropes}}},
  booktitle = {Proceedings of the 29th {{International Conference}} on {{Computational Linguistics}}},
